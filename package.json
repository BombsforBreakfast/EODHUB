{
  "name": "eod-job-board",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/fetch-disposable-domains.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:image-transforms": "node scripts/check-supabase-image-transforms.mjs",
    "test:feed-ranking": "tsx scripts/verify-feed-ranking.ts",
    "test:mux-video": "tsx scripts/verify-mux-feed-video.ts",
    "test:news": "tsx app/lib/news/goldenLasd.verify.ts",
    "linkedin:login": "tsx scripts/linkedin-jobs-import.ts --login",
    "linkedin:import": "tsx scripts/linkedin-jobs-import.ts",
    "linkedin:import:dry": "tsx scripts/linkedin-jobs-import.ts --dry-run --force",
    "linkedin:install-task": "powershell -ExecutionPolicy Bypass -File scripts/register-linkedin-import-task.ps1",
    "linkedin:uninstall-task": "powershell -ExecutionPolicy Bypass -File scripts/register-linkedin-import-task.ps1 -Unregister",
    "refresh:disposable": "node scripts/fetch-disposable-domains.mjs",
    "cap:sync": "npx cap sync",
    "cap:sync:ios": "npx cap sync ios",
    "cap:sync:android": "npx cap sync android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "generate:splash": "node scripts/generate-splash.mjs"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
