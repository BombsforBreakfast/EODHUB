    "docx-preview": "^0.3.7",
    "emoji-mart": "^5.6.0",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.7",
